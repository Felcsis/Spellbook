// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
    // Further reading:
    // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
    // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
    url      = env("SPELLBOOK_DATABASE_URL")
}

model Post {
    id        Int      @id @default(autoincrement())
    name      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    createdBy   User   @relation(fields: [createdById], references: [id])
    createdById String

    @@index([name])
}

// Necessary for Next auth
model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? // @db.Text
    access_token             String? // @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? // @db.Text
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id             String         @id @default(cuid())
    name           String?
    email          String?        @unique
    emailVerified  DateTime?
    image          String?
    password       String?
    role           String         @default("staff")  // "admin" | "staff"
    accounts       Account[]
    sessions       Session[]
    posts          Post[]
    financeEntries     FinanceEntry[]
    workDays           WorkDay[]
    serviceCategories  ServiceCategory[]
    services           Service[]
    guestCards         GuestCard[]
    expenses           Expense[]  @relation("ExpenseCreatedBy")
    assignedExpenses   Expense[]  @relation("ExpenseAssignedTo")
}

model WorkDay {
    id            String           @id @default(cuid())
    date          DateTime         @db.Date
    user          User             @relation(fields: [userId], references: [id])
    userId        String
    earnings      Float            @default(0)
    notes         String?
    financeEntry  FinanceEntry?
    services      WorkDayService[]

    @@unique([date, userId])
    @@index([date])
}

model WorkDayService {
    id         String   @id @default(cuid())
    workDay    WorkDay  @relation(fields: [workDayId], references: [id], onDelete: Cascade)
    workDayId  String
    service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
    serviceId  String
    quantity   Int      @default(1)
    priceSnap  Float    // ár a bejegyzés pillanatában

    @@unique([workDayId, serviceId])
}

model FinanceEntry {
    id          String     @id @default(cuid())
    type        String     // "revenue" | "material" | "wage"
    description String
    amount      Float
    date        DateTime   @default(now())
    createdAt   DateTime   @default(now())
    createdBy   User       @relation(fields: [createdById], references: [id])
    createdById String
    workDay     WorkDay?   @relation(fields: [workDayId], references: [id], onDelete: Cascade)
    workDayId   String?    @unique
    guestCard   GuestCard? @relation(fields: [guestCardId], references: [id], onDelete: SetNull)
    guestCardId String?
    visitGroupId String?

    @@index([date])
    @@index([type])
    @@index([visitGroupId])
}

model Guest {
    id        String      @id @default(cuid())
    name      String
    phone     String?
    notes     String?
    createdAt DateTime    @default(now())
    cards     GuestCard[]

    @@index([name])
}

model GuestCard {
    id            String              @id @default(cuid())
    date          DateTime            @db.Date
    guest         Guest               @relation(fields: [guestId], references: [id], onDelete: Cascade)
    guestId       String
    worker        User                @relation(fields: [workerId], references: [id])
    workerId      String
    total         Float               @default(0)
    notes         String?
    createdAt     DateTime            @default(now())
    services       GuestCardService[]
    materials      GuestCardMaterial[]
    financeEntries FinanceEntry[]

    @@index([guestId])
    @@index([date])
}

model GuestCardService {
    id           String    @id @default(cuid())
    card         GuestCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
    cardId       String
    name         String
    price        Float
    duration     Int       @default(0)
    gender       String?
    categoryName String?
}

model GuestCardMaterial {
    id        String    @id @default(cuid())
    card      GuestCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
    cardId    String
    name      String
    brand     String?
    colorCode String?
    grams     Float
    unitPrice Float
    lineTotal Float
}

model Material {
    id        String   @id @default(cuid())
    name      String
    price     Float
    unit      String?  // pl. "adag", "tubus", "csomag"
    active    Boolean  @default(true)
    order     Int      @default(0)
    createdAt DateTime @default(now())

    @@index([name])
}

model Expense {
    id           String   @id @default(cuid())
    title        String
    amount       Float
    date         DateTime @db.Date
    category     String   @default("egyéb")
    notes        String?
    paid         Boolean  @default(true)
    createdAt    DateTime @default(now())
    createdBy    User     @relation("ExpenseCreatedBy", fields: [createdById], references: [id])
    createdById  String
    assignedTo   User?    @relation("ExpenseAssignedTo", fields: [assignedToId], references: [id])
    assignedToId String?

    @@index([date])
    @@index([assignedToId])
}

model SalonSetting {
    id                   String   @id @default("singleton")
    googleRefreshToken   String?
    googleCalendarId     String?
    updatedAt            DateTime @updatedAt
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

model ServiceCategory {
    id            String    @id @default(cuid())
    name          String
    order         Int       @default(0)
    priceListType String    @default("master")
    createdAt     DateTime  @default(now())
    user          User      @relation(fields: [userId], references: [id])
    userId        String
    services      Service[]

    @@index([userId])
    @@index([priceListType])
}

model Service {
    id           String           @id @default(cuid())
    name         String
    price        Float
    duration     Int              @default(30)
    description  String?
    active       Boolean          @default(true)
    order        Int              @default(0)
    createdAt    DateTime         @default(now())
    category     ServiceCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
    categoryId   String
    user         User             @relation(fields: [userId], references: [id])
    userId       String
    workDays     WorkDayService[]

    @@index([categoryId])
    @@index([userId])
}
